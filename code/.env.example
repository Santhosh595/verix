# Copy to .env and fill in. Never commit the real .env.

VLM_PROVIDER=openrouter
VLM_MODEL=openai/gpt-oss-120b:free
VLM_FALLBACK_MODEL=deepseek/deepseek-chat:free

OPENROUTER_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

VLM_TEMPERATURE=0
MAX_RETRIES=3
REQUEST_TIMEOUT_SECONDS=60
MAX_REQUESTS_PER_MINUTE=30
